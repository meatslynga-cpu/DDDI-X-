name: Build DDDI-X AAB

on:
  push:
    branches: [ main ]
  workflow_dispatch:

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
      - name: Set up JDK 17
        uses: actions/setup-java@v3
        with:
          java-version: '17'
          distribution: 'temurin'

      - name: Set up Android SDK
        uses: android-actions/setup-android@v3

      - name: Create project structure
        run: |
          mkdir -p DDDI-X/app/src/main/java/com/dddi/x
          mkdir -p DDDI-X/app/src/main/res/layout
          mkdir -p DDDI-X/app/src/main/res/values
          mkdir -p DDDI-X/app/src/main/res/drawable
          mkdir -p DDDI-X/app/src/main/res/xml
          mkdir -p DDDI-X/app/src/main/res/mipmap-anydpi-v26
          mkdir -p DDDI-X/app/src/main/assets
          mkdir -p DDDI-X/gradle/wrapper
          mkdir -p DDDI-X/.github/workflows

      - name: Write settings.gradle
        run: |
          cat > DDDI-X/settings.gradle << 'EOF'
          pluginManagement {
              repositories {
                  google()
                  mavenCentral()
                  gradlePluginPortal()
              }
          }
          dependencyResolutionManagement {
              repositoriesMode.set(RepositoriesMode.FAIL_ON_PROJECT_REPOS)
              repositories {
                  google()
                  mavenCentral()
              }
          }
          rootProject.name = "DDDI-X"
          include ':app'
          EOF

      - name: Write root build.gradle
        run: |
          cat > DDDI-X/build.gradle << 'EOF'
          plugins {
              id 'com.android.application' version '8.1.0' apply false
          }
          EOF

      - name: Write gradle.properties
        run: |
          cat > DDDI-X/gradle.properties << 'EOF'
          org.gradle.jvmargs=-Xmx2048m -Dfile.encoding=UTF-8
          android.useAndroidX=true
          android.enableJetifier=true
          EOF

      - name: Write gradle-wrapper.properties
        run: |
          cat > DDDI-X/gradle/wrapper/gradle-wrapper.properties << 'EOF'
          distributionBase=GRADLE_USER_HOME
          distributionPath=wrapper/dists
          distributionUrl=https\://services.gradle.org/distributions/gradle-8.0-bin.zip
          zipStoreBase=GRADLE_USER_HOME
          zipStorePath=wrapper/dists
          EOF

      - name: Download gradlew
        run: |
          cd DDDI-X
          curl -L https://raw.githubusercontent.com/gradle/gradle/v8.0.0/gradlew -o gradlew
          chmod +x gradlew

      - name: Write app build.gradle
        run: |
          cat > DDDI-X/app/build.gradle << 'EOF'
          plugins {
              id 'com.android.application'
          }
          android {
              namespace 'com.dddi.x'
              compileSdk 34
              defaultConfig {
                  applicationId "com.dddi.x"
                  minSdk 24
                  targetSdk 34
                  versionCode 3
                  versionName "3.0"
              }
              buildTypes {
                  release {
                      minifyEnabled false
                      proguardFiles getDefaultProguardFile('proguard-android-optimize.txt'), 'proguard-rules.pro'
                  }
              }
              compileOptions {
                  sourceCompatibility JavaVersion.VERSION_1_8
                  targetCompatibility JavaVersion.VERSION_1_8
              }
          }
          dependencies {
              implementation 'androidx.appcompat:appcompat:1.6.1'
          }
          EOF

      - name: Write AndroidManifest.xml
        run: |
          cat > DDDI-X/app/src/main/AndroidManifest.xml << 'EOF'
          <?xml version="1.0" encoding="utf-8"?>
          <manifest xmlns:android="http://schemas.android.com/apk/res/android"
              package="com.dddi.x">
              <uses-permission android:name="android.permission.INTERNET" />
              <application
                  android:allowBackup="true"
                  android:icon="@drawable/ic_launcher"
                  android:label="@string/app_name"
                  android:theme="@style/Theme.DDDIX"
                  android:usesCleartextTraffic="true">
                  <activity
                      android:name=".MainActivity"
                      android:exported="true"
                      android:screenOrientation="portrait">
                      <intent-filter>
                          <action android:name="android.intent.action.MAIN" />
                          <category android:name="android.intent.category.LAUNCHER" />
                      </intent-filter>
                  </activity>
              </application>
          </manifest>
          EOF

      - name: Write MainActivity.java
        run: |
          cat > DDDI-X/app/src/main/java/com/dddi/x/MainActivity.java << 'EOF'
          package com.dddi.x;
          import android.annotation.SuppressLint;
          import android.app.Activity;
          import android.os.Bundle;
          import android.webkit.WebSettings;
          import android.webkit.WebView;
          import android.webkit.WebViewClient;
          public class MainActivity extends Activity {
              private WebView webView;
              @SuppressLint("SetJavaScriptEnabled")
              @Override
              protected void onCreate(Bundle savedInstanceState) {
                  super.onCreate(savedInstanceState);
                  setContentView(R.layout.activity_main);
                  webView = findViewById(R.id.webView);
                  WebSettings s = webView.getSettings();
                  s.setJavaScriptEnabled(true);
                  s.setDomStorageEnabled(true);
                  s.setAllowFileAccessFromFileURLs(true);
                  s.setAllowUniversalAccessFromFileURLs(true);
                  webView.setWebViewClient(new WebViewClient());
                  webView.loadUrl("file:///android_asset/dddi_x.html");
              }
              @Override
              public void onBackPressed() {
                  if (webView.canGoBack()) webView.goBack();
                  else super.onBackPressed();
              }
          }
          EOF

      - name: Write layout
        run: |
          cat > DDDI-X/app/src/main/res/layout/activity_main.xml << 'EOF'
          <?xml version="1.0" encoding="utf-8"?>
          <RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
              android:layout_width="match_parent"
              android:layout_height="match_parent">
              <WebView
                  android:id="@+id/webView"
                  android:layout_width="match_parent"
                  android:layout_height="match_parent" />
          </RelativeLayout>
          EOF

      - name: Write strings.xml
        run: |
          cat > DDDI-X/app/src/main/res/values/strings.xml << 'EOF'
          <?xml version="1.0" encoding="utf-8"?>
          <resources>
              <string name="app_name">DDDI-X</string>
          </resources>
          EOF

      - name: Write themes.xml
        run: |
          cat > DDDI-X/app/src/main/res/values/themes.xml << 'EOF'
          <?xml version="1.0" encoding="utf-8"?>
          <resources>
              <style name="Theme.DDDIX" parent="android:Theme.Material.NoActionBar">
                  <item name="android:windowBackground">#12120F</item>
                  <item name="android:statusBarColor">#12120F</item>
                  <item name="android:navigationBarColor">#12120F</item>
              </style>
          </resources>
          EOF

      - name: Write colors.xml
        run: |
          cat > DDDI-X/app/src/main/res/values/colors.xml << 'EOF'
          <?xml version="1.0" encoding="utf-8"?>
          <resources>
              <color name="dark">#12120F</color>
              <color name="red">#B03030</color>
          </resources>
          EOF

      - name: Write launcher icon
        run: |
          cat > DDDI-X/app/src/main/res/drawable/ic_launcher.xml << 'EOF'
          <?xml version="1.0" encoding="utf-8"?>
          <vector xmlns:android="http://schemas.android.com/apk/res/android"
              android:width="108dp" android:height="108dp"
              android:viewportWidth="108" android:viewportHeight="108">
              <path android:fillColor="#12120F" android:pathData="M0,0h108v108h-108z"/>
              <path android:fillColor="#B03030" android:pathData="M0,0h108v8h-108z"/>
              <path android:strokeColor="#FDFAF4" android:strokeWidth="6"
                  android:strokeLineCap="round" android:pathData="M32,32 L76,76"/>
              <path android:strokeColor="#FDFAF4" android:strokeWidth="6"
                  android:strokeLineCap="round" android:pathData="M76,32 L32,76"/>
          </vector>
          EOF

      - name: Write proguard-rules.pro
        run: touch DDDI-X/app/proguard-rules.pro

      - name: Download DDDI-X HTML app
        run: |
          curl -L "https://ais-dev-2sr2ky6smj42pn7zihjxpq-377331845620.us-west2.run.app" \
            -o DDDI-X/app/src/main/assets/dddi_x.html || \
          echo "Network fetch failed â€” using embedded fallback" && \
          echo "<html><body><h1>DDDI-X</h1><p>App asset missing.</p></body></html>" \
            > DDDI-X/app/src/main/assets/dddi_x.html

      - name: Build AAB
        run: |
          cd DDDI-X
          ./gradlew bundleDebug

      - name: Upload AAB
        uses: actions/upload-artifact@v3
        with:
          name: DDDI-X-debug.aab
          path: DDDI-X/app/build/outputs/bundle/debug/app-debug.aab
